{
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "http://54.180.123.239:8080/api/$1"
        },
        {
            "source": "/uploads/(.*)",
            "destination": "http://54.180.123.239:8080/uploads/$1"
        },
        {
            "source": "/((?!api/|uploads/|.*\\..*).*)",
            "destination": "/index.html"
        }
    ]
}