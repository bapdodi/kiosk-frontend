{
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "https://kioskserver.bapdodi.cloud/api/$1"
        },
        {
            "source": "/uploads/(.*)",
            "destination": "https://kioskserver.bapdodi.cloud/uploads/$1"
        },
        {
            "source": "/((?!api/|uploads/|.*\\..*).*)",
            "destination": "/index.html"
        }
    ]
}